# Copy this file to .env and set real values
BOT_TOKEN=your_bot_token_here

# Access control (set one or both)
ALLOWED_USER_ID=0
ALLOWED_USER_IDS=

# Permanent public URL (e.g. from a named Cloudflare Tunnel or reverse proxy).
# If set, cloudflared quick-tunnel is skipped entirely and this URL is used for the Telegram webhook.
# If unset, start.ps1 / restart.ps1 will launch a temporary cloudflared quick-tunnel automatically.
PUBLIC_URL=