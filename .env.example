# Copy this file to .env and set real values
BOT_TOKEN=your_bot_token_here

# Access control (set one or both)
ALLOWED_USER_ID=0
ALLOWED_USER_IDS=

# Optional: explicit Copilot executable
# Example (Windows): C:\Users\<you>\AppData\Roaming\Code\User\globalStorage\github.copilot-chat\copilotCli\copilot.ps1
COPILOT_COMMAND=

# Optional runtime settings
COPILOT_CONFIG_DIR=
COPILOT_TIMEOUT_SECONDS=180
SESSION_LIST_LIMIT=10
