# Copy this file to .env and set real values
BOT_TOKEN=your_bot_token_here

# Access control
# - ALLOWED_USER_IDS: comma-separated whitelist (recommended)
# - ALLOWED_USER_ID: single-value compatibility key
ALLOWED_USER_ID=0
ALLOWED_USER_IDS=

# Permanent public URL (e.g. from a named Cloudflare Tunnel or reverse proxy).
# If set, cloudflared quick-tunnel is skipped entirely and this URL is used for the Telegram webhook.
# If unset, start.ps1 / restart.ps1 will launch a temporary cloudflared quick-tunnel automatically.
PUBLIC_URL=

# Copilot CLI timeout (seconds)
COPILOT_TIMEOUT_SECONDS=180

# Minimum confidence required for action-plan parser (below this will fail-closed to approval)
PLAN_CONFIDENCE_THRESHOLD=0.7

# C-Phase5 shadow enforcement kill switch (default off)
# - false: legacy behavior
# - true: enforce according to SHADOW_ENFORCEMENT_SCOPE
SHADOW_ENFORCEMENT_ENABLED=false

# C-Phase5 enforcement scope
# - deny_only: force block when shadow strategy is deny
# - deny_and_challenge: deny_only + force approval when strategy is challenge
SHADOW_ENFORCEMENT_SCOPE=deny_only

# Session list command count
SESSION_LIST_LIMIT=10

# Scope key used by project-level approval grants
PROJECT_SCOPE_KEY=

# Note:
# - High-risk requests require Telegram approval by default.
# - Approval grants support one-time / conversation / project / agent scopes.
# - Current /agent selection is persisted in approval_store.json.
# - Execution replies use a two-stage format: "1,..." then "2,...".
# - Runtime state is persisted to approval_store.json (grants/pending/user agent/session mapping).
# - Audit events are appended to audit_log.jsonl.